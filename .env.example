# 실제 값은 .env에 작성하고 git에 커밋하지 않는다.
UPSTAGE_API_KEY=
SOLAR_MODEL=solar-pro2-251215
UPSTAGE_API_BASE=https://api.upstage.ai/v1

# UI 디자인/배포 연결만 빠르게 확인할 때 1로 설정한다 (main.py/streamlit_app.py 공유).
USE_MOCK_LLM=0

# Kakao Local API — 열린 업종 키워드·"근처" 거리 필터에 사용 (developers.kakao.com)
KAKAO_REST_API_KEY=

# Langfuse (선택, 운영 관측용): 셋 다 채우면 Solar 호출(입력/출력/지연시간/비용)이
# 자동으로 추적된다. 비워두면 solar_llm.py가 그냥 무시하고 평소처럼 동작한다.
# 키 발급: https://cloud.langfuse.com 가입 → 프로젝트 생성 → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
